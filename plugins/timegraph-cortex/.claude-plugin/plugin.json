{
  "name": "timegraph-cortex",
  "version": "0.2.0",
  "description": "Automatic memory for Claude Code. Every turn is ingested into a temporal graph; every prompt is augmented with relevant prior context. No manual recall calls.",
  "author": {
    "name": "Jameson",
    "url": "https://github.com/jamoeight"
  },
  "homepage": "https://github.com/jamoeight/cortex-mcp",
  "repository": "https://github.com/jamoeight/cortex-mcp",
  "license": "Apache-2.0",
  "keywords": ["memory", "context", "recall", "mcp", "rag", "temporal-graph"],
  "mcpServers": {
    "timegraph": {
      "command": "timegraph-mcp",
      "env": {
        "TG_JUDGE_BACKEND": "claude_cli",
        "TG_JUDGE_CLAUDE_MODEL": "haiku",
        "TG_EXTRACTOR_BACKEND": "claude_cli",
        "TG_EXTRACTOR_CLAUDE_MODEL": "haiku"
      }
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "timegraph-hook-ingest",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "timegraph-hook-recall",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write|NotebookEdit|NotebookRead|Bash|PowerShell|Grep|Glob|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "timegraph-hook-tool-use",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "timegraph-hook-session-start",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
